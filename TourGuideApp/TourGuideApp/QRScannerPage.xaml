<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="TourGuideApp.QRScannerPage"
             Title="Quét mã QR"
             BackgroundColor="Black">

    <Grid>
        <zxing:CameraBarcodeReaderView 
            x:Name="barcodeReader"
            BarcodesDetected="BarcodeReader_BarcodesDetected" />

        <Border Stroke="Red" StrokeThickness="3" BackgroundColor="Transparent" 
                WidthRequest="250" HeightRequest="250" HorizontalOptions="Center" VerticalOptions="Center" />

        <Label Text="Hướng camera vào mã QR" TextColor="White" BackgroundColor="#80000000" 
               HorizontalOptions="Center" VerticalOptions="End" Margin="0,0,0,50" Padding="15" />
    </Grid>

</ContentPage>