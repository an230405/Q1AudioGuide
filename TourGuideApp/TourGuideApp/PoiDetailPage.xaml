<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideApp.PoiDetailPage"
             Title="Chi tiết địa điểm">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Frame HasShadow="True" Padding="0" CornerRadius="10" IsClippedToBounds="True">
                <Image x:Name="PoiImage" 
                       HeightRequest="250" 
                       Aspect="AspectFill" 
                       Source="{Binding ImageUrl}" />
            </Frame>

            <Label x:Name="NameLabel" 
                   Text="{Binding Name}"
                   FontSize="28" 
                   FontAttributes="Bold" 
                   TextColor="#2B3C58"
                   HorizontalOptions="Start" />

            <Label x:Name="TitleLabel" 
                   Text="{Binding Content.Title}"
                   FontSize="18" 
                   FontAttributes="Italic" 
                   TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" />

            <Label x:Name="DescriptionLabel" 
                   Text="{Binding Content.Description}"
                   FontSize="16" 
                   LineHeight="1.5"
                   TextColor="#444" />

            <Button Text="🔊 Nghe thuyết minh" 
                    Clicked="OnSpeakClicked"
                    BackgroundColor="#512BD4" 
                    TextColor="White" 
                    CornerRadius="25"
                    HeightRequest="50"
                    Margin="0,20,0,0" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>