<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideApp.PoiDetailPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">
    <Grid RowDefinitions="Auto, *, Auto">

        <Grid Grid.Row="0" BackgroundColor="#2563EB" Padding="15">
            <Grid ColumnDefinitions="*, Auto">
                <Button Grid.Column="0" x:Name="btnBack" Text="❮ Quay lại" Clicked="OnBackClicked" HorizontalOptions="Start" BackgroundColor="Transparent" TextColor="White" FontSize="16" FontAttributes="Bold" Padding="0" />
                <ImageButton Grid.Column="1" Source="share_icon.png" Clicked="OnShareClicked" HeightRequest="24" BackgroundColor="Transparent" />
            </Grid>
        </Grid>

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="0">
                <Image x:Name="imgPoi" Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="250" />

                <VerticalStackLayout Padding="20" Spacing="15">
                    <Label x:Name="lblName" Text="{Binding Name}" FontSize="26" FontAttributes="Bold" TextColor="#2563EB" />

                    <Label x:Name="lblDistance" FontSize="16" TextColor="#E65100" FontAttributes="Italic" Margin="0,-10,0,10" />

                    <Button x:Name="btnSpeak" Text="🔊 Nghe thuyết minh" Clicked="OnSpeakClicked" BackgroundColor="#2563EB" TextColor="White" FontAttributes="Bold" CornerRadius="12" HeightRequest="50" />

                    <Label x:Name="lblDescription" Text="{Binding FinalDescription}" FontSize="16" TextColor="#333333" LineHeight="1.5" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

        <Grid Grid.Row="2" BackgroundColor="#2563EB" ColumnDefinitions="*, *, *" Padding="0, 10, 0, 0" HeightRequest="65">

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFooterHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="🏠" TextColor="#A0AEC0" FontSize="20" HorizontalOptions="Center"/>
                <Label x:Name="lblHome" Text="Trang chủ" TextColor="#A0AEC0" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFooterListTapped"/>
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="📋" TextColor="#A0AEC0" FontSize="20" HorizontalOptions="Center"/>
                <Label x:Name="lblList" Text="Danh sách" TextColor="#A0AEC0" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFooterQrTapped"/>
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="📷" TextColor="#A0AEC0" FontSize="20" HorizontalOptions="Center"/>
                <Label x:Name="lblQr" Text="Quét QR" TextColor="#A0AEC0" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>