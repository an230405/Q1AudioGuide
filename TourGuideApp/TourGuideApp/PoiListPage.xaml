<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideApp.PoiListPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F3F4F6">

    <Grid RowDefinitions="Auto, *, Auto">

        <SearchBar x:Name="searchBar" Grid.Row="0" BackgroundColor="White" TextColor="Black" CancelButtonColor="Gray" Margin="10" TextChanged="OnSearchTextChanged"/>

        <CollectionView x:Name="poiCollectionView" Grid.Row="1" Margin="10,0,10,10">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Margin="0,0,0,12" Padding="10" CornerRadius="12" BackgroundColor="White" BorderColor="#E5E7EB" HasShadow="True">
                        <Frame.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnFrameTapped" CommandParameter="{Binding .}" />
                        </Frame.GestureRecognizers>

                        <Grid ColumnDefinitions="90, *, Auto" ColumnSpacing="15">
                            <Frame Grid.Column="0" Padding="0" CornerRadius="8" IsClippedToBounds="True" HasShadow="False" BackgroundColor="#E5E7EB">
                                <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="80" WidthRequest="90" />
                            </Frame>

                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="5">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16" TextColor="#1F2937" MaxLines="2" LineBreakMode="TailTruncation" />
                                <Label Text="{Binding DistanceToUser, StringFormat='📍 {0:F2} km'}" FontSize="14" TextColor="#2563EB" FontAttributes="Bold" />
                            </VerticalStackLayout>

                            <Image Grid.Column="2" Source="chevron_right.png" HeightRequest="20" VerticalOptions="Center" Opacity="0.4" />
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2" BackgroundColor="#2563EB" ColumnDefinitions="*, *, *" Padding="0, 10, 0, 0" HeightRequest="65">

            <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFooterHomeTapped"/>
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="🏠" TextColor="#A0AEC0" FontSize="20" HorizontalOptions="Center"/>
                <Label x:Name="lblHome" Text="Trang chủ" TextColor="#A0AEC0" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                <Label Text="📋" TextColor="White" FontSize="20" HorizontalOptions="Center"/>
                <Label x:Name="lblList" Text="Danh sách" TextColor="White" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                <VerticalStackLayout.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnFooterQrTapped"/>
                </VerticalStackLayout.GestureRecognizers>
                <Label Text="📷" TextColor="#A0AEC0" FontSize="20" HorizontalOptions="Center"/>
                <Label x:Name="lblQr" Text="Quét QR" TextColor="#A0AEC0" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
            </VerticalStackLayout>

        </Grid>
    </Grid>
</ContentPage>