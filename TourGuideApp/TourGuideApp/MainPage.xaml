<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TourGuideApp.MainPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             BackgroundColor="White">

    <Grid>
        <BoxView HeightRequest="300" VerticalOptions="Start">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#2563EB" Offset="0.1" />
                    <GradientStop Color="#60A5FA" Offset="1.0" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <VerticalStackLayout Spacing="0" VerticalOptions="FillAndExpand">

            <VerticalStackLayout Padding="30, 70, 30, 40" Spacing="10">
                <Label x:Name="lblGreeting" Text="Hello! 👋" FontSize="20" TextColor="#DBEAFE" FontAttributes="Bold" />
                <Label x:Name="lblTitle" Text="Explore Saigon" FontSize="32" FontAttributes="Bold" TextColor="White" LineHeight="1.1" />
                <Label x:Name="lblSubTitle" Text="Your companion on every road" TextColor="White" Opacity="0.9" FontSize="15" />
            </VerticalStackLayout>

            <Frame Margin="0" Padding="30, 40, 30, 30" CornerRadius="40" BackgroundColor="White" HasShadow="False" VerticalOptions="FillAndExpand">
                <VerticalStackLayout Spacing="35">

                    <FlexLayout Wrap="Wrap" JustifyContent="SpaceBetween" AlignContent="Center" AlignItems="Center">

                        <VerticalStackLayout WidthRequest="90" Spacing="8">
                            <Frame HeightRequest="65" WidthRequest="65" CornerRadius="32" BackgroundColor="#EFF6FF" BorderColor="Transparent" Padding="0" HasShadow="False">
                                <Label Text="📍" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <Label x:Name="lblFeature1" Text="Navigation" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#1E3A8A" />
                        </VerticalStackLayout>

                        <VerticalStackLayout WidthRequest="90" Spacing="8">
                            <Frame HeightRequest="65" WidthRequest="65" CornerRadius="32" BackgroundColor="#EFF6FF" BorderColor="Transparent" Padding="0" HasShadow="False">
                                <Label Text="🎧" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <Label x:Name="lblFeature2" Text="Audio Guide" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#1E3A8A" />
                        </VerticalStackLayout>

                        <VerticalStackLayout WidthRequest="90" Spacing="8">
                            <Frame HeightRequest="65" WidthRequest="65" CornerRadius="32" BackgroundColor="#EFF6FF" BorderColor="Transparent" Padding="0" HasShadow="False">
                                <Label Text="🌐" FontSize="28" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Frame>
                            <Label x:Name="lblFeature3" Text="Multi-lang" FontSize="13" FontAttributes="Bold" HorizontalOptions="Center" TextColor="#1E3A8A" />
                        </VerticalStackLayout>

                    </FlexLayout>

                    <VerticalStackLayout Spacing="15">
                        <Label x:Name="lblLangPrompt" Text="Which language do you prefer?" FontSize="16" FontAttributes="Bold" TextColor="#475569" HorizontalOptions="Center" />

                        <Frame Padding="15, 0" CornerRadius="20" BackgroundColor="#F1F5F9" BorderColor="Transparent" HasShadow="False" HeightRequest="60">
                            <Picker x:Name="langPicker" Title="Tap to select..." FontSize="17" TextColor="#1E293B" HorizontalTextAlignment="Center" SelectedIndexChanged="OnLanguageChanged" />
                        </Frame>
                    </VerticalStackLayout>

                    <Button x:Name="btnStart" Text="EXPLORE NOW" Clicked="OnStartClicked"
                            BackgroundColor="#2563EB" TextColor="White" FontAttributes="Bold" FontSize="17"
                            CornerRadius="20" HeightRequest="65" VerticalOptions="End">
                        <Button.Shadow>
                            <Shadow Brush="#2563EB" Offset="0,10" Radius="20" Opacity="0.3" />
                        </Button.Shadow>
                    </Button>

                </VerticalStackLayout>
            </Frame>
        </VerticalStackLayout>

        <Grid x:Name="loadingOverlay" BackgroundColor="#CCFFFFFF" IsVisible="False">
            <VerticalStackLayout VerticalOptions="Center" Spacing="25">
                <ActivityIndicator IsRunning="True" Color="#2563EB" Scale="1.5" />
                <Label x:Name="lblLoading" Text="Preparing journey..." TextColor="#2563EB" FontSize="18" FontAttributes="Bold" HorizontalOptions="Center" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
    