<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:mapsui="clr-namespace:Mapsui.UI.Maui;assembly=Mapsui.UI.Maui"
             x:Class="TourGuideApp.MapPage"
             NavigationPage.HasNavigationBar="False"
             Shell.NavBarIsVisible="False"
             Padding="0">

    <Grid RowDefinitions="*, Auto" BackgroundColor="#2563EB">
        <Frame x:Name="frmNetworkStatus" HasShadow="True" CornerRadius="15" Padding="10,5"
               HorizontalOptions="Center" VerticalOptions="Start" Margin="0,40,0,0"
               BackgroundColor="#dcfce7" BorderColor="Transparent" ZIndex="100">
            <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                <BoxView x:Name="dotStatus" Color="#22c55e" WidthRequest="10" HeightRequest="10" 
                         CornerRadius="5" VerticalOptions="Center"/>
                <Label x:Name="lblNetStatus" Text="Online" TextColor="#166534" 
                       FontSize="12" FontAttributes="Bold" VerticalOptions="Center"/>
            </HorizontalStackLayout>
        </Frame>

        <mapsui:MapView x:Name="mapView" 
                        Grid.RowSpan="2"
                        PinClicked="OnPinClicked" 
                        HorizontalOptions="FillAndExpand" 
                        VerticalOptions="FillAndExpand" />

        <Button Text="❮" Clicked="OnExitToMainClicked" 
                BackgroundColor="White" TextColor="#2563EB" 
                FontSize="22" FontAttributes="Bold" 
                WidthRequest="45" HeightRequest="45" 
                CornerRadius="22" Padding="0" 
                HorizontalOptions="Start" VerticalOptions="Start" 
                Margin="15, 35, 0, 0">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="5" Opacity="0.2"/>
            </Button.Shadow>
        </Button>

        <Button Text="🎯" Clicked="OnCenterUserLocationClicked" 
                BackgroundColor="White" TextColor="#2563EB" 
                FontSize="20" WidthRequest="45" HeightRequest="45" 
                CornerRadius="22" Padding="0" 
                HorizontalOptions="End" VerticalOptions="Start" 
                Margin="0, 35, 15, 0">
            <Button.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="5" Opacity="0.2"/>
            </Button.Shadow>
        </Button>

        <Grid Grid.Row="1" VerticalOptions="End">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="65" />
            </Grid.RowDefinitions>

            <Frame Grid.Row="0" Margin="15, 0, 15, 10" Padding="20" CornerRadius="20" BackgroundColor="White" HasShadow="True">
                <VerticalStackLayout Spacing="8">
                    <HorizontalStackLayout Spacing="5">
                        <Label Text="📍" FontSize="16"/>
                        <Label x:Name="lblStatus" Text="Địa điểm gần bạn:" TextColor="Gray" FontSize="14" FontAttributes="Bold" VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label x:Name="lblLocationName" Text="Đang tải..." FontSize="22" FontAttributes="Bold" TextColor="#2563EB" />
                    <Label x:Name="lblDistance" Text="Cách bạn: 0 km" TextColor="#E65100" FontSize="15" FontAttributes="Bold" Margin="0,0,0,5"/>
                    <Button x:Name="btnAudio" Text="▶ PHÁT THUYẾT MINH" Clicked="OnPlayAudioClicked" BackgroundColor="#2563EB" TextColor="White" FontAttributes="Bold" CornerRadius="12" HeightRequest="45" />
                </VerticalStackLayout>
            </Frame>

            <Grid Grid.Row="1" BackgroundColor="#2563EB" ColumnDefinitions="*, *, *" Padding="0, 10, 0, 0">

                <VerticalStackLayout Grid.Column="0" HorizontalOptions="Center">
                    <Label Text="🏠" TextColor="White" FontSize="20" HorizontalOptions="Center"/>
                    <Label x:Name="lblHome" Text="Trang chủ" TextColor="White" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="1" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnListClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="📋" TextColor="#A0AEC0" FontSize="20" HorizontalOptions="Center"/>
                    <Label x:Name="lblList" Text="Danh sách" TextColor="#A0AEC0" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <VerticalStackLayout Grid.Column="2" HorizontalOptions="Center">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnScanQrClicked"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Label Text="📷" TextColor="#A0AEC0" FontSize="20" HorizontalOptions="Center"/>
                    <Label x:Name="lblQr" Text="Quét QR" TextColor="#A0AEC0" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>

            </Grid>
        </Grid>
    </Grid>
</ContentPage>