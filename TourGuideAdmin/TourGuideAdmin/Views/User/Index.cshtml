@model List<UserViewModel>
@{
    ViewData["Title"] = "Người dùng";
}
<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">Tổng: <strong>@Model.Count</strong> người dùng</p>
    
    @if (User.IsInRole("admin") || User.IsInRole("Admin"))
    {
        <a href="/User/Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Thêm người dùng</a>
    }
</div>

<div class="admin-table">
    <table class="table table-hover mb-0">
        <thead>
            <tr><th>ID</th><th>Tên đăng nhập</th><th>Vai trò</th><th>Ngày tạo</th><th></th></tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="5" class="text-center text-muted py-5">Chưa có người dùng nào</td></tr>
            }
            @foreach (var u in Model)
            {
                <tr>
                    <td class="text-muted" style="font-size:12px;">#@u.Id</td>
                    <td class="fw-500"><i class="bi bi-person-circle me-1 text-muted"></i>@u.Username</td>
                    <td>
                        @if (u.Role == "admin")
                        {
                            <span class="badge" style="background:rgba(245,166,35,.15);color:#d4861a;">Admin</span>
                        }
                        else
                        {

                            <span class="badge bg-light text-dark">@u.Role</span>
                        }
                    </td>
                    <td style="font-size:12px;color:#7a8099;">@u.CreatedAt?.ToString("dd/MM/yyyy HH:mm")</td>
                    <td class="text-end">
                        @if (User.IsInRole("admin") || User.IsInRole("Admin"))
                        {
                            <a href="/User/Edit/@u.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                            <form method="post" action="/User/Delete/@u.Id" style="display:inline"
                                  onsubmit="return confirm('Xóa người dùng @u.Username?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>