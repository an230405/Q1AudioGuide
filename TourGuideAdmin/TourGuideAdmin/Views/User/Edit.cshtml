@model UserViewModel
@{ ViewData["Title"] = "Sửa Người dùng"; }

<div class="mb-3">
    <a href="/User" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>
<div class="form-card" style="max-width:480px;">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label">Tên đăng nhập</label>
                <input asp-for="Username" class="form-control" />
            </div>
            <div class="col-12">
                <label class="form-label">Vai trò</label>
                <select asp-for="Role" class="form-select">
                    <option value="admin">Admin</option>
                    <option value="editor">Editor</option>
                    <option value="viewer">Viewer</option>
                </select>
            </div>
            <div class="col-12 pt-2">
                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i>Cập nhật</button>
                <a href="/User" class="btn btn-outline-secondary ms-2">Hủy</a>
            </div>
        </div>
    </form>
</div>
