@model UserViewModel
@{
    ViewData["Title"] = "Chỉnh sửa Người dùng";
}

<div class="mb-3">
    <a href="/User" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>

<div class="form-card" style="max-width:480px;">
    <form asp-action="Edit" method="post">
        <input type="hidden" asp-for="Id" />
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label">Tên đăng nhập</label>
                <input asp-for="Username" class="form-control" readonly style="background-color: #f8f9fa;" />
                <small class="text-muted">Tên đăng nhập không được phép thay đổi.</small>
            </div>
            
            <div class="col-12">
                <label class="form-label">Mật khẩu mới</label>
                <input asp-for="Password" type="password" class="form-control" placeholder="Để trống nếu không muốn đổi" />
                <small class="text-muted">Chỉ nhập nếu Anh muốn đặt lại mật khẩu cho người dùng này.</small>
            </div>

            <div class="col-12">
                <label class="form-label">Vai trò</label>
                <select asp-for="Role" class="form-select">
                    <option value="admin">Admin (Toàn quyền)</option>
                    <option value="viewer">Viewer (Chỉ xem)</option>
                </select>
            </div>

            <div class="col-12 pt-2">
                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-save me-1"></i>Cập nhật</button>
                <a href="/User" class="btn btn-outline-secondary ms-2">Hủy</a>
            </div>
        </div>
    </form>
</div>