@model List<LanguageViewModel>
@{ ViewData["Title"] = "Ngôn ngữ"; }

<div class="d-flex justify-content-between align-items-center mb-3">
    <p class="text-muted mb-0">Tổng: <strong>@Model.Count</strong> ngôn ngữ</p>
    <a href="/Language/Create" class="btn btn-primary"><i class="bi bi-plus-lg me-1"></i>Thêm ngôn ngữ</a>
</div>
<div class="admin-table">
    <table class="table table-hover mb-0">
        <thead>
            <tr><th>ID</th><th>Mã (Code)</th><th>Tên ngôn ngữ</th><th></th></tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr><td colspan="4" class="text-center text-muted py-5">Chưa có ngôn ngữ nào</td></tr>
            }
            @foreach (var lang in Model)
            {
                <tr>
                    <td class="text-muted" style="font-size:12px;">#@lang.Id</td>
                    <td><span class="badge bg-secondary">@lang.Code?.ToUpper()</span></td>
                    <td class="fw-500">@lang.Name</td>
                    <td class="text-end">
                        <a href="/Language/Edit/@lang.Id" class="btn btn-sm btn-outline-secondary me-1"><i class="bi bi-pencil"></i></a>
                        <form method="post" action="/Language/Delete/@lang.Id" style="display:inline"
                              onsubmit="return confirm('Xóa ngôn ngữ @lang.Name?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
