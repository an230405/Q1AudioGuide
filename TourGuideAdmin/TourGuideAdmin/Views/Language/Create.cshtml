@model LanguageViewModel
@{ ViewData["Title"] = "Thêm Ngôn ngữ"; }

<div class="mb-3">
    <a href="/Language" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>
<div class="form-card" style="max-width:480px;">
    <form asp-action="Create" method="post">
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label">Mã ngôn ngữ <span class="text-danger">*</span></label>
                <input asp-for="Code" class="form-control" placeholder="VD: vi, en, ja, zh" required />
                <div class="form-text">Dùng mã ISO 639-1 (2 ký tự), chữ thường</div>
            </div>
            <div class="col-12">
                <label class="form-label">Tên ngôn ngữ <span class="text-danger">*</span></label>
                <input asp-for="Name" class="form-control" placeholder="VD: Tiếng Việt" required />
            </div>
            <div class="col-12 pt-2">
                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i>Lưu</button>
                <a href="/Language" class="btn btn-outline-secondary ms-2">Hủy</a>
            </div>
        </div>
    </form>
</div>
