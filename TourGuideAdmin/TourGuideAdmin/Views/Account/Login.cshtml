@{
    ViewData["Title"] = "Đăng nhập";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập – Audio Guide Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Be Vietnam Pro', sans-serif; }
        body {
            min-height: 100vh; margin: 0;
            background: linear-gradient(135deg, #1a1d2e 0%, #2d3150 50%, #1a1d2e 100%);
            display: flex; align-items: center; justify-content: center;
        }
        .login-box {
            background: #fff; border-radius: 16px;
            padding: 40px 36px; width: 100%; max-width: 400px;
            box-shadow: 0 20px 60px rgba(0,0,0,.3);
        }
        .brand { text-align: center; margin-bottom: 28px; }
        .brand-icon {
            width: 60px; height: 60px; border-radius: 14px;
            background: linear-gradient(135deg, #f5a623, #e8764a);
            display: inline-flex; align-items: center; justify-content: center;
            font-size: 28px; margin-bottom: 12px;
        }
        .brand-name { font-size: 20px; font-weight: 700; color: #1a1d2e; }
        .brand-sub { font-size: 12px; color: #7a8099; }
        .form-label { font-size: 13px; font-weight: 600; color: #4a5068; }
        .form-control {
            border-radius: 8px; border-color: #dde1ee;
            font-size: 14px; padding: 10px 14px;
        }
        .form-control:focus { border-color: #f5a623; box-shadow: 0 0 0 3px rgba(245,166,35,.15); }
        .input-group-text {
            border-color: #dde1ee; background: #f8f9fc;
            border-radius: 8px 0 0 8px; color: #7a8099;
        }
        .input-group .form-control { border-radius: 0 8px 8px 0; }
        .btn-login {
            background: linear-gradient(135deg, #f5a623, #e8764a);
            border: none; color: #fff; font-weight: 700;
            font-size: 15px; padding: 11px; border-radius: 8px;
            width: 100%; transition: opacity .2s;
        }
        .btn-login:hover { opacity: .9; color: #fff; }
        .alert-danger { border-radius: 8px; font-size: 13px; }
        .toggle-pw { cursor: pointer; border-color: #dde1ee; background: #f8f9fc;
            border-radius: 0 8px 8px 0; color: #7a8099; }
    </style>
</head>
<body>
<div class="login-box">
    <div class="brand">
        <div class="brand-icon">🎧</div>
        <div class="brand-name">Audio Guide Admin</div>
        <div class="brand-sub">Q1 Tour – Hệ thống quản trị</div>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger py-2 mb-3">
            <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error
        </div>
    }

    <form method="post" action="/Account/Login">
        <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />

        <div class="mb-3">
            <label class="form-label">Tên đăng nhập</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-person"></i></span>
                <input type="text" name="username" class="form-control"
                       placeholder="Nhập tên đăng nhập" required autofocus />
            </div>
        </div>

        <div class="mb-4">
            <label class="form-label">Mật khẩu</label>
            <div class="input-group">
                <span class="input-group-text"><i class="bi bi-lock"></i></span>
                <input type="password" name="password" id="pwInput"
                       class="form-control" placeholder="Nhập mật khẩu" required />
                <button type="button" class="btn toggle-pw border"
                        onclick="togglePw()">
                    <i class="bi bi-eye" id="eyeIcon"></i>
                </button>
            </div>
        </div>

        <button type="submit" class="btn-login">
            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
        </button>
    </form>
</div>

<script>
function togglePw() {
    const input = document.getElementById('pwInput');
    const icon = document.getElementById('eyeIcon');
    if (input.type === 'password') {
        input.type = 'text';
        icon.className = 'bi bi-eye-slash';
    } else {
        input.type = 'password';
        icon.className = 'bi bi-eye';
    }
}
</script>
</body>
</html>
