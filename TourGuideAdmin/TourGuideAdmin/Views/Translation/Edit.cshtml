@model TranslationViewModel
@{ ViewData["Title"] = "Sửa Bản dịch"; }

<div class="mb-3">
    <a href="/Translation" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Quay lại</a>
</div>
<div class="form-card">
    <form asp-action="Edit" asp-route-id="@Model.Id" method="post">
        <input asp-for="Id" type="hidden" />
        <div class="row g-3">
            <div class="col-md-6">
                <label class="form-label">Địa điểm</label>
                <select asp-for="PoiId" asp-items="ViewBag.Pois" class="form-select">
                    <option value="">-- Chọn địa điểm --</option>
                </select>
            </div>
            <div class="col-md-6">
                <label class="form-label">Ngôn ngữ</label>
                <select asp-for="LanguageId" asp-items="ViewBag.Languages" class="form-select">
                    <option value="">-- Chọn ngôn ngữ --</option>
                </select>
            </div>
            <div class="col-12">
                <label class="form-label">Tiêu đề</label>
                <input asp-for="Title" class="form-control" />
            </div>
            <div class="col-12">
                <label class="form-label">Nội dung mô tả</label>
                <textarea asp-for="Content" class="form-control" rows="6"></textarea>
            </div>
            <div class="col-12 pt-2">
                <button type="submit" class="btn btn-primary px-4"><i class="bi bi-check-lg me-1"></i>Cập nhật</button>
                <a href="/Translation" class="btn btn-outline-secondary ms-2">Hủy</a>
            </div>
        </div>
    </form>
</div>
