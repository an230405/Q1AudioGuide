<div class="row g-3">
    <div class="col-xl-8">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-header bg-white pb-0 pt-3 border-0 d-flex justify-content-between align-items-center">
                <h5 class="card-title fw-bold text-primary mb-0">
                    <i class="bi bi-bar-chart-fill me-2"></i>Top 5 Địa điểm được nghe nhiều nhất
                </h5>
                <select id="timeFilter" class="form-select form-select-sm" style="width: 160px; cursor: pointer;" onchange="updateChart()">
                    <option value="all">Tất cả thời gian</option>
                    <option value="today">Hôm nay</option>
                    <option value="7days">7 ngày qua</option>
                    <option value="30days">30 ngày qua</option>
                </select>
            </div>
            <div class="card-body">
                <canvas id="topPoiChart" height="120"></canvas>
            </div>
        </div>
    </div>

    <div class="col-xl-4">
        <div class="admin-table h-100">
            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                <h6 class="mb-0" style="font-weight:700;">Địa điểm mới nhất</h6>
                <a href="/POI/Create" class="btn btn-sm btn-primary">+ Thêm</a>
            </div>
            <table class="table mb-0">
                <thead>
                    <tr><th>Tên địa điểm</th><th>Trạng thái</th></tr>
                </thead>
                <tbody>
                    @if (!Model.RecentPOIs.Any())
                    {
                        <tr><td colspan="2" class="text-center text-muted py-4">Chưa có dữ liệu</td></tr>
                    }
                    @foreach (var poi in Model.RecentPOIs)
                    {
                        <tr>
                            <td><a href="/POI/Edit/@poi.Id" class="text-decoration-none fw-500">@poi.Name</a></td>
                            <td>
                                @if (poi.IsActive == true)
                                {
                                    <span class="badge-active">Hiện</span>
                                }
                                else
                                {
                                    <span class="badge-inactive">Ẩn</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        // ===============================================
        // 1. KHỞI TẠO BIỂU ĐỒ BAN ĐẦU
        // ===============================================
        var listNames = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopPoiNames));
        var listCounts = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.TopPoiListens));

        var ctx = document.getElementById('topPoiChart').getContext('2d');
        var topPoiChart = new Chart(ctx, {
        type: 'bar',
        data: {
        labels: listNames,
        datasets: [{
        label: 'Số lượt nghe',
        data: listCounts,
        backgroundColor: [
        'rgba(54, 162, 235, 0.7)', 'rgba(255, 99, 132, 0.7)',
        'rgba(255, 206, 86, 0.7)', 'rgba(75, 192, 192, 0.7)', 'rgba(153, 102, 255, 0.7)'
        ],
        borderColor: [
        'rgba(54, 162, 235, 1)', 'rgba(255, 99, 132, 1)',
        'rgba(255, 206, 86, 1)', 'rgba(75, 192, 192, 1)', 'rgba(153, 102, 255, 1)'
        ],
        borderWidth: 1,
        borderRadius: 5
        }]
        },
        options: {
        responsive: true,
        scales: {
        y: { beginAtZero: true, ticks: { precision: 0 } }
        },
        plugins: { legend: { display: false } }
        }
        });

        // ===============================================
        // 👉 2. HÀM CẬP NHẬT BIỂU ĐỒ KHI ĐỔI BỘ LỌC THỜI GIAN
        // ===============================================
        function updateChart() {
        var period = document.getElementById('timeFilter').value;
            
        // Gọi AJAX về HomeController -> GetChartData
        fetch('/Home/GetChartData?period=' + period)
        .then(response => response.json())
        .then(data => {
        if (data.success) {
        // Nạp dữ liệu mới vào Chart và vẽ lại
        topPoiChart.data.labels = data.names;
        topPoiChart.data.datasets[0].data = data.counts;
        topPoiChart.update();
        }
        })
        .catch(err => console.log("Lỗi tải biểu đồ:", err));
        }

        // ===============================================
        // 3. CHỨC NĂNG LẤY SỐ ONLINE THEO THỜI GIAN THỰC
        // ===============================================
        setInterval(function () {
        fetch('/Home/GetOnlineCount')
        .then(response => response.json())
        .then(data => {
        const countElement = document.getElementById('online-count');
        if (countElement) {
        countElement.innerText = data.count;
        countElement.style.transition = "0.3s";
        countElement.style.opacity = "0.5";
        setTimeout(() => countElement.style.opacity = "1", 300);
        }
        })
        .catch(err => console.log("Lỗi lấy số online:", err));
        }, 3000);
    </script>
}
