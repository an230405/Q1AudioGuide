<div class="row g-3">
    <!-- Recent Audio Logs -->
    <div class="col-xl-8">
        <div class="admin-table">
            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                <h6 class="mb-0 fw-700" style="font-weight:700;">Nhật ký phát gần đây</h6>
                <a href="/AudioLog" class="btn btn-sm btn-outline-secondary">Xem tất cả</a>
            </div>
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>Device ID</th>
                        <th>Địa điểm</th>
                        <th>Ngôn ngữ</th>
                        <th>Thời gian</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.RecentLogs.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">Chưa có dữ liệu</td></tr>
                    }
                    @foreach (var log in Model.RecentLogs)
                    {
                        <tr>
                            <td><code style="font-size:12px;">@(log.DeviceId?.Length > 12 ? log.DeviceId[..12] + "…" : log.DeviceId)</code></td>
                            <td>@log.PoiName</td>
                            <td><span class="badge bg-light text-dark">@log.LanguageName</span></td>
                            <td style="font-size:12px;color:#7a8099;">@log.PlayTime?.ToString("dd/MM HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    <!-- Recent POIs -->
    <div class="col-xl-4">
        <div class="admin-table">
            <div class="d-flex align-items-center justify-content-between px-4 py-3 border-bottom">
                <h6 class="mb-0" style="font-weight:700;">Địa điểm mới nhất</h6>
                <a href="/POI/Create" class="btn btn-sm btn-primary">+ Thêm</a>
            </div>
            <table class="table mb-0">
                <thead>
                    <tr><th>Tên địa điểm</th><th>Trạng thái</th></tr>
                </thead>
                <tbody>
                    @if (!Model.RecentPOIs.Any())
                    {
                        <tr><td colspan="2" class="text-center text-muted py-4">Chưa có dữ liệu</td></tr>
                    }
                    @foreach (var poi in Model.RecentPOIs)
                    {
                        <tr>
                            <td><a href="/POI/Edit/@poi.Id" class="text-decoration-none fw-500">@poi.Name</a></td>
                            <td>
                                @if (poi.IsActive == true)
                                { <span class="badge-active">Hiện</span> }
                                else
                                { <span class="badge-inactive">Ẩn</span> }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        // Cứ mỗi 3 giây (3000ms) sẽ tự động chạy hàm lấy số Online
        setInterval(function () {
            fetch('/Home/GetOnlineCount') // Nó sẽ gọi vào một hàm phụ trong Controller
                .then(response => response.json())
                .then(data => {
                    // Tìm đến cái ô có ID là "online-count" để thay số mới vào
                    const countElement = document.getElementById('online-count');
                    if (countElement) {
                        countElement.innerText = data.count;
                        
                        // Hiệu ứng nháy xanh nhẹ một cái cho chuyên nghiệp
                        countElement.style.transition = "0.3s";
                        countElement.style.opacity = "0.5";
                        setTimeout(() => countElement.style.opacity = "1", 300);
                    }
                })
                .catch(err => Console.log("Lỗi lấy số online:", err));
        }, 3000);
    </script>
}