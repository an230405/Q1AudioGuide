<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] – Audio Guide Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        :root {
            --sidebar-w: 240px;
            --primary: #f5a623;
            --primary-dark: #d4861a;
            --bg: #f4f6fa;
            --sidebar-bg: #1a1d2e;
            --sidebar-text: #a8afc9;
            --sidebar-active: #f5a623;
        }
        body { font-family: 'Be Vietnam Pro', sans-serif; background: var(--bg); }

        /* ── Sidebar ── */
        .sidebar {
            width: var(--sidebar-w); min-height: 100vh;
            background: var(--sidebar-bg); position: fixed; top: 0; left: 0;
            display: flex; flex-direction: column; z-index: 1000;
        }
        .sidebar-brand {
            padding: 24px 20px 16px;
            border-bottom: 1px solid rgba(255,255,255,.07);
        }
        .sidebar-brand .brand-name { font-size: 17px; font-weight: 700; color: var(--primary); line-height: 1.2; }
        .sidebar-brand .brand-sub { font-size: 10px; color: var(--sidebar-text); letter-spacing: 1.5px; text-transform: uppercase; }
        .sidebar-nav { flex: 1; padding: 12px 0; overflow-y: auto; }
        .nav-section-label {
            font-size: 9px; font-weight: 600; letter-spacing: 2px; text-transform: uppercase;
            color: rgba(168,175,201,.4); padding: 12px 20px 4px;
        }
        .sidebar-link {
            display: flex; align-items: center; gap: 10px;
            padding: 9px 20px; color: var(--sidebar-text); text-decoration: none;
            font-size: 13.5px; font-weight: 500; border-left: 3px solid transparent;
            transition: all .15s;
        }
        .sidebar-link:hover { color: #fff; background: rgba(255,255,255,.05); }
        .sidebar-link.active { color: var(--primary); background: rgba(245,166,35,.1); border-left-color: var(--primary); }
        .sidebar-link i { font-size: 16px; width: 18px; text-align: center; }
        .sidebar-footer { padding: 16px 20px; border-top: 1px solid rgba(255,255,255,.07); }
        .api-badge {
            display: inline-flex; align-items: center; gap: 6px;
            font-size: 11px; color: var(--sidebar-text);
        }
        .dot { width: 7px; height: 7px; border-radius: 50%; background: #3ecf8e; animation: blink 2s infinite; }
        @@keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

        /* ── Main content ── */
        .main-wrapper { margin-left: var(--sidebar-w); }
        .topbar {
            background: #fff; border-bottom: 1px solid #e5e9f2;
            padding: 12px 28px; display: flex; align-items: center; justify-content: space-between;
            position: sticky; top: 0; z-index: 100;
        }
        .topbar-title { font-size: 18px; font-weight: 700; color: #1a1d2e; margin: 0; }
        .content-area { padding: 28px; }

        /* ── Cards ── */
        .stat-card {
            background: #fff; border-radius: 12px; padding: 22px 24px;
            border: 1px solid #e5e9f2; transition: box-shadow .2s;
        }
        .stat-card:hover { box-shadow: 0 4px 20px rgba(0,0,0,.08); }
        .stat-icon {
            width: 46px; height: 46px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center; font-size: 20px;
        }
        .stat-num { font-size: 28px; font-weight: 700; color: #1a1d2e; line-height: 1.1; }
        .stat-label { font-size: 12px; color: #7a8099; font-weight: 500; margin-top: 2px; }

        /* ── Tables ── */
        .admin-table { background: #fff; border-radius: 12px; border: 1px solid #e5e9f2; overflow: hidden; }
        .admin-table .table { margin: 0; }
        .admin-table .table th { background: #f8f9fc; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: .8px; color: #7a8099; border-bottom: 1px solid #e5e9f2; padding: 12px 16px; }
        .admin-table .table td { padding: 12px 16px; font-size: 13.5px; vertical-align: middle; border-color: #f0f2f8; }
        .admin-table .table tbody tr:hover { background: #fafbff; }

        /* ── Buttons ── */
        .btn-primary { background: var(--primary); border-color: var(--primary); color: #fff; font-weight: 600; }
        .btn-primary:hover { background: var(--primary-dark); border-color: var(--primary-dark); color: #fff; }
        .btn-sm { font-size: 12px; padding: 4px 10px; border-radius: 6px; }

        /* ── Forms ── */
        .form-card { background: #fff; border-radius: 12px; border: 1px solid #e5e9f2; padding: 28px; }
        .form-label { font-size: 13px; font-weight: 600; color: #4a5068; }
        .form-control, .form-select { border-radius: 8px; border-color: #dde1ee; font-size: 13.5px; }
        .form-control:focus, .form-select:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(245,166,35,.15); }

        /* ── Status badges ── */
        .badge-active { background: rgba(62,207,142,.1); color: #1a9e6e; font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 20px; }
        .badge-inactive { background: rgba(248,113,113,.1); color: #dc3545; font-size: 11px; font-weight: 600; padding: 3px 9px; border-radius: 20px; }

        /* ── Alerts ── */
        .toast-container { position: fixed; bottom: 24px; right: 24px; z-index: 9999; }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

<!-- Sidebar -->
<aside class="sidebar">
    <div class="sidebar-brand">
        <div class="brand-name">🎧 Audio Guide</div>
        <div class="brand-sub">Admin Panel – Q1 Tour</div>
    </div>
    <nav class="sidebar-nav">
        <div class="nav-section-label">Tổng quan</div>
        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Home" ? "active" : "")"
           href="/">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <div class="nav-section-label">Nội dung</div>
        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "POI" ? "active" : "")"
           href="/POI">
            <i class="bi bi-geo-alt"></i> Địa điểm (POI)
        </a>
        @* <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Audio" ? "active" : "")"
           href="/Audio">
            <i class="bi bi-music-note-beamed"></i> Audio
        </a> *@
        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Translation" ? "active" : "")"
           href="/Translation">
            <i class="bi bi-translate"></i> Bản dịch
        </a>

        <div class="nav-section-label">Hệ thống</div>
        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Language" ? "active" : "")"
           href="/Language">
            <i class="bi bi-globe"></i> Ngôn ngữ
        </a>
        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "User" ? "active" : "")"
           href="/User">
            <i class="bi bi-people"></i> Người dùng
        </a>
        @* <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "AudioLog" ? "active" : "")"
           href="/AudioLog">
            <i class="bi bi-journal-text"></i> Nhật ký phát
        </a> *@
        <a class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "QrCode" ? "active" : "")"
           href="/QrCode">
            <i class="bi bi-qr-code"></i> QR Code
        </a>
    </nav>
    <div class="sidebar-footer">
        <span class="api-badge"><span class="dot"></span> API đang kết nối</span>
    </div>
</aside>

<!-- Main -->
<div class="main-wrapper">
    <div class="topbar">
        <h1 class="topbar-title">@ViewData["Title"]</h1>
        <div class="d-flex align-items-center gap-3">
            <span style="font-size:13px;color:#4a5068;">
                <i class="bi bi-person-circle me-1"></i>@User.Identity?.Name
            </span>
            <form method="post" action="/Account/Logout" style="margin:0;">
                @Html.AntiForgeryToken()
                <button type="submit" class="btn btn-sm btn-outline-secondary">
                    <i class="bi bi-box-arrow-right me-1"></i>Đăng xuất
                </button>
            </form>
        </div>
    </div>
    <div class="content-area">

        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
                <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
